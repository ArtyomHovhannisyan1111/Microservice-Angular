<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260625-2" author="admin">
        <addColumn tableName="notifications">
            <column name="total_price" type="NUMERIC(38, 2)"/>
        </addColumn>

        <update tableName="notifications">
            <column name="total_price" valueNumeric="0"/>
            <where>total_price IS NULL</where>
        </update>

        <addNotNullConstraint
                tableName="notifications"
                columnName="total_price"
                columnDataType="NUMERIC(38, 2)"/>
    </changeSet>

</databaseChangeLog>
